{
  "name": "plat-verify",
  "displayName": "plat-verify",
  "description": "Architecture conformance verification for plat manifests",
  "version": "0.1.0",
  "publisher": "plat",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/cwd-k2/plat"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Linters",
    "Programming Languages"
  ],
  "activationEvents": [
    "workspaceContains:plat-verify.toml",
    "workspaceContains:*.plat.json"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "plat-verify",
      "properties": {
        "plat-verify.serverPath": {
          "type": "string",
          "default": "plat-verify",
          "description": "Path to the plat-verify binary"
        },
        "plat-verify.manifestPath": {
          "type": "string",
          "default": "",
          "description": "Path to the manifest JSON file (auto-detected if empty)"
        },
        "plat-verify.configPath": {
          "type": "string",
          "default": "plat-verify.toml",
          "description": "Path to the plat-verify config file"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
